# ARGUS — Environment Variables
# Скопируй этот файл как .env и заполни своими ключами
# Никогда не публикуй .env в GitHub

# ── Обязательно для EVM сетей ─────────────────────────────────────────
# Получить бесплатно: https://etherscan.io/register
ETHERSCAN_API_KEY=your_etherscan_key_here

# ── Для argus_youtube.py и argus_yt_monitor.py ────────────────────────
# console.cloud.google.com → APIs → YouTube Data API v3 → Credentials
YOUTUBE_API_KEY=your_youtube_key_here

# ── Для argus_yt_monitor.py (опционально) ────────────────────────────
# console.cloud.google.com → APIs → Custom Search API
# Search Engine ID: cse.google.com → Create engine → site:youtube.com
GOOGLE_CSE_KEY=your_google_cse_key_here
GOOGLE_CSE_CX=your_search_engine_id_here
